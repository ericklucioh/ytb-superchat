{
  "name": "Portal do Streamer - Eloh",
  "description": "Captura chats ao vivo de plataformas como YouTube, Twitch e Kick para o portal do Streamer. A sessão é definida pelo portal.",
  "manifest_version": 3,
  "version": "0.0.3",
  "homepage_url": "https://ytb.ericklucioh.com/",
  "icons": {
    "128": "icons/logoWhite.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.sli.do/*",
    "https://youtube.com/*",
    "https://www.youtube.com/*",
    "https://studio.youtube.com/*",
    "https://www.twitch.tv/*",
    "https://glimesh.tv/*",
    "https://chat.restream.io/*",
    "https://www.instagram.com/*",
    "https://instagram.com/*",
    "https://trovo.live/chat/*",
    "https://kick.com/*",
    "https://www.twitter.com/*",
    "https://facebook.com/*",
    "https://*.zoom.us/*",
    "https://www.facebook.com/*",
    "https://www.mobcrush.com/*",
    "https://www.crowdcast.io/e/*",
    "https://www.polleverywhere.com/discourses/*",
    "https://viz.polleverywhere.com/discourses/*",
    "http://localhost/*",
    "https://localhost/*",
    "https://ytb.ericklucioh.com/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
	  {
		"css": ["main.css"],
		"js": ["sources/logger.js", "sources/shared-runtime.js", "sources/local-chat-bridge.js", "sources/avatar-helpers.js", "jquery.js", "sources/youtube.js"],
		"matches": ["https://youtube.com/live_chat*", "https://www.youtube.com/live_chat*", "https://studio.youtube.com/live_chat*"]
	  },
	  {
		"css": ["main.css"],
		"js": ["sources/logger.js", "sources/shared-runtime.js", "sources/slido.js"],
		"matches": ["https://*.sli.do/*"]
	  },
	  {
		"css": ["main.css"],
		"js": ["sources/logger.js", "sources/shared-runtime.js", "sources/local-chat-bridge.js", "sources/avatar-helpers.js", "jquery.js", "sources/twitch.js"],
		"matches": ["https://www.twitch.tv/popout/*"]
	  },
	  {
		"css": ["main.css"],
		"js": ["sources/logger.js", "sources/shared-runtime.js", "sources/local-chat-bridge.js", "sources/avatar-helpers.js", "sources/kick.js"],
		"matches": ["https://kick.com/popout/*/chat", "https://kick.com/*/popout/*/chat", "https://kick.com/*/chatroom"]
	  },
	  {
		"css": ["main.css"],
		"js": ["sources/logger.js", "sources/shared-runtime.js", "sources/local-chat-bridge.js", "jquery.js", "sources/glimesh.js"],
		"matches": ["https://glimesh.tv/*/chat"]
	  },
	  {
		"css": ["main.css"],
		"js": ["sources/logger.js", "sources/shared-runtime.js", "sources/local-chat-bridge.js", "jquery.js", "sources/restream.js"],
		"matches": ["https://chat.restream.io/*"]
	  },
	  {
		"css": ["main.css"],
		"js": ["sources/logger.js", "sources/shared-runtime.js", "sources/local-chat-bridge.js", "jquery.js", "sources/trovo.js"],
		"matches": ["https://trovo.live/chat/*"]
		},
	   {
		"css": ["main.css"],
		"js": ["sources/logger.js", "sources/shared-runtime.js", "sources/local-chat-bridge.js", "jquery.js", "sources/instagram.js"],
		"matches": ["https://instagram.com/*","https://www.instagram.com/*"]
	  },
	   {
		"css": ["main.css"],
		"js": ["sources/logger.js", "sources/shared-runtime.js", "sources/local-chat-bridge.js", "sources/instalive.js"],
		"matches": ["https://instagram.com/*/live/","https://www.instagram.com/*/live/"]
	  },
	   {
		"css": ["main.css"],
		"js": ["sources/logger.js", "sources/shared-runtime.js", "sources/local-chat-bridge.js", "jquery.js", "sources/twitter.js"],
		"matches": ["https://twitter.com/*","https://www.twitter.com/*"]
	  },
	   {
		"css": ["main.css"],
		"js": ["sources/logger.js", "sources/shared-runtime.js", "sources/local-chat-bridge.js", "sources/facebook.js"],
		"matches": ["https://facebook.com/*","https://www.facebook.com/*"]
	  },
	   {
		"css": ["main.css"],
		"js": ["sources/logger.js", "sources/shared-runtime.js", "sources/local-chat-bridge.js", "jquery.js", "sources/mobcrush.js"],
		"matches": ["https://www.mobcrush.com/*/chat.slobs"]
	  },
	   {
		"css": ["main.css"],
		"js": ["sources/logger.js", "sources/shared-runtime.js", "sources/local-chat-bridge.js", "sources/crowdcast.js"],
		"matches": ["https://www.crowdcast.io/e/*"]
	  },
	   {
		"css": ["main.css"],
		"js": ["sources/logger.js", "sources/shared-runtime.js", "sources/local-chat-bridge.js", "sources/zoom.js"],
		"matches": ["https://*.zoom.us/*"]
	  },
	   {
		"css": [],
		"js": ["sources/logger.js", "sources/shared-runtime.js", "sources/local-chat-bridge.js", "sources/withyt.js"],
		"matches": ["https://*.withyoutube.com/*"]
	  },
	   {
		"css": ["main.css"],
		"js": ["sources/logger.js", "sources/shared-runtime.js", "sources/local-chat-bridge.js", "sources/polleverywhere.js"],
		"matches": ["https://www.polleverywhere.com/discourses/*", "https://viz.polleverywhere.com/discourses/*"],
		"all_frames": true
	  }
	  ,
	  {
		"css": [],
		"js": ["sources/logger.js", "sources/shared-runtime.js", "sources/local-chat-bridge.js", "sources/dashboard-relay.js"],
		"matches": ["http://localhost/*", "https://localhost/*", "https://ytb.ericklucioh.com/*"],
		"run_at": "document_start"
	  }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "facebook.png",
        "glimesh.png",
        "polleverywhere.png",
        "trovo.png",
        "twitch.png",
        "unknown.png",
        "youtube.png",
        "zoom.png"
      ],
      "matches": [
        "https://*.sli.do/*",
        "https://youtube.com/*",
        "https://www.youtube.com/*",
        "https://studio.youtube.com/*",
        "https://www.twitch.tv/*",
        "https://glimesh.tv/*",
        "https://chat.restream.io/*",
        "https://www.instagram.com/*",
        "https://instagram.com/*",
        "https://trovo.live/*",
        "https://kick.com/*",
        "https://www.twitter.com/*",
        "https://twitter.com/*",
        "https://facebook.com/*",
        "https://www.facebook.com/*",
        "https://*.zoom.us/*",
        "https://www.mobcrush.com/*",
        "https://www.crowdcast.io/*",
        "https://www.polleverywhere.com/*",
        "https://viz.polleverywhere.com/*",
        "http://localhost/*",
        "https://localhost/*",
        "https://ytb.ericklucioh.com/*"
      ]
    },
    {
      "resources": [
        "sources/dashboard-page-shim.js"
      ],
      "matches": [
        "http://localhost/*",
        "https://localhost/*",
        "https://ytb.ericklucioh.com/*"
      ]
    }
  ],
  "options_ui": {
    "page": "settings/options.html"
  }
}
