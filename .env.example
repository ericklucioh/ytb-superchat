# Copy to `.env.development.local` for local work.
# Copy to `.env.production.local` for production builds or CI.

YTB_APP_ENV=development
PORT=8000
YTB_GO_PORT=8080
YTB_OVERLAY_API_BASE_URL=http://localhost:8080
PUBLIC_BACKEND_URL=http://localhost:8080
# Optional alias used by production deployments.
YTB_PUBLIC_BACKEND_URL=
YTB_OVERLAY_WS_URL=ws://localhost:8080/ws
YTB_SESSION_ID=
YTB_PORTAL_MOCK=0
