# Production build defaults.
# Replace the API URL with your hosted backend.
YTB_APP_ENV=production
PORT=8000
YTB_GO_PORT=8080
YTB_OVERLAY_API_BASE_URL=https://chat.ericklucioh.com
PUBLIC_BACKEND_URL=https://chat.ericklucioh.com
